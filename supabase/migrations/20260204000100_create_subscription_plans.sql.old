-- Creates a DB-backed subscription plan catalog for /api/subscriptions/plans

create table if not exists public.subscription_plans (
  plan_id text primary key,
  audience text not null default 'consumer' check (audience in ('consumer', 'creator', 'both')),
  name text not null,
  price_mwk integer not null default 0,
  billing_interval text not null default 'month',
  currency text not null default 'MWK',
  active boolean not null default true,
  sort_order integer not null default 0,
  features jsonb,
  marketing jsonb,
  created_at timestamptz not null default now(),
  updated_at timestamptz not null default now()
);
-- If the table already exists (schema drift), ensure indexed columns exist.
alter table public.subscription_plans
  add column if not exists active boolean not null default true;
alter table public.subscription_plans
  add column if not exists audience text not null default 'consumer';
alter table public.subscription_plans
  add column if not exists role text;
alter table public.subscription_plans
  add column if not exists plan text;
alter table public.subscription_plans
  add column if not exists name text;
alter table public.subscription_plans
  add column if not exists price integer not null default 0;
alter table public.subscription_plans
  add column if not exists price_mwk integer not null default 0;
alter table public.subscription_plans
  add column if not exists billing_interval text not null default 'month';
alter table public.subscription_plans
  add column if not exists currency text not null default 'MWK';
alter table public.subscription_plans
  add column if not exists sort_order integer not null default 0;
alter table public.subscription_plans
  add column if not exists features jsonb;
alter table public.subscription_plans
  add column if not exists marketing jsonb;
alter table public.subscription_plans
  add column if not exists created_at timestamptz not null default now();
alter table public.subscription_plans
  add column if not exists updated_at timestamptz not null default now();
create index if not exists subscription_plans_active_idx on public.subscription_plans(active);
create index if not exists subscription_plans_audience_idx on public.subscription_plans(audience);
-- Keep updated_at current
create or replace function public.set_updated_at() returns trigger
language plpgsql
as $$
begin
  new.updated_at = now();
  return new;
end;
$$;
drop trigger if exists set_updated_at_subscription_plans on public.subscription_plans;
create trigger set_updated_at_subscription_plans
before update on public.subscription_plans
for each row execute function public.set_updated_at();
-- Seed defaults (consumer).
-- Use ordered statements instead of data-modifying CTEs so reruns see prior cleanup
-- work and cannot re-insert the same canonical plan_id in the same migration.
do $$
begin
  create temporary table subscription_plan_seed_rows (
    plan_id text primary key,
    audience text,
    role text,
    plan text,
    name text,
    price integer,
    price_mwk integer,
    billing_interval text,
    currency text,
    active boolean,
    sort_order integer,
    features jsonb,
    marketing jsonb
  ) on commit drop;

  insert into subscription_plan_seed_rows (
    plan_id,
    audience,
    role,
    plan,
    name,
    price,
    price_mwk,
    billing_interval,
    currency,
    active,
    sort_order,
    features,
    marketing
  )
  values
    (
      'free',
      'consumer',
      'consumer',
      'free',
      'Free',
      0,
      0,
      'month',
      'MWK',
      true,
      0,
      '{"ads":true}'::jsonb,
      '{"tagline":"Listen for free","bullets":["Ad-supported listening"]}'::jsonb
    ),
    (
      'premium',
      'consumer',
      'consumer',
      'premium',
      'Premium',
      15000,
      15000,
      'month',
      'MWK',
      true,
      10,
      '{"ads":false,"offline":true,"audio_quality":"320kbps","create_playlist":true,"watch_live_battles":true,"cancel_anytime":true}'::jsonb,
      '{"tagline":"Offline listening + live battles.","bullets":["Download to listen offline","High audio quality up to 320 kbps","Create playlists","Watch live artists/DJs battles","Cancel anytime"]}'::jsonb
    ),
    (
      'platinum',
      'consumer',
      'consumer',
      'platinum',
      'Platinum',
      20000,
      20000,
      'month',
      'MWK',
      true,
      20,
      '{"ads":false,"offline":true,"audio_quality":"24bit/44.1kHz","mix_playlist":true,"ai_dj":true,"watch_live_battles":true,"cancel_anytime":true}'::jsonb,
      '{"tagline":"Studio quality + AI DJ.","bullets":["Download to listen offline","Audio quality up to 24-bit/44.1kHz","Mix your playlist","Your personal AI DJ","Watch live artists/DJs battle streaming","Cancel anytime"]}'::jsonb
    );

  delete from public.subscription_plans sp
  using subscription_plan_seed_rows sr
  where sp.role = sr.role
    and sp.plan = sr.plan
    and coalesce(sp.billing_interval, 'month') = sr.billing_interval
    and sp.plan_id is distinct from sr.plan_id
    and exists (
      select 1
      from public.subscription_plans existing
      where existing.plan_id = sr.plan_id
    );

  update public.subscription_plans sp
  set
    plan_id = sr.plan_id,
    audience = sr.audience,
    role = sr.role,
    plan = sr.plan,
    name = sr.name,
    price = sr.price,
    price_mwk = sr.price_mwk,
    billing_interval = sr.billing_interval,
    currency = sr.currency,
    active = sr.active,
    sort_order = sr.sort_order,
    features = sr.features,
    marketing = sr.marketing
  from subscription_plan_seed_rows sr
  where sp.role = sr.role
    and sp.plan = sr.plan
    and coalesce(sp.billing_interval, 'month') = sr.billing_interval
    and sp.plan_id is distinct from sr.plan_id
    and not exists (
      select 1
      from public.subscription_plans existing
      where existing.plan_id = sr.plan_id
    );

  insert into public.subscription_plans (
    plan_id,
    audience,
    role,
    plan,
    name,
    price,
    price_mwk,
    billing_interval,
    currency,
    active,
    sort_order,
    features,
    marketing
  )
  select
    sr.plan_id,
    sr.audience,
    sr.role,
    sr.plan,
    sr.name,
    sr.price,
    sr.price_mwk,
    sr.billing_interval,
    sr.currency,
    sr.active,
    sr.sort_order,
    sr.features,
    sr.marketing
  from subscription_plan_seed_rows sr
  on conflict (plan_id) do update set
    audience = excluded.audience,
    role = excluded.role,
    plan = excluded.plan,
    name = excluded.name,
    price = excluded.price,
    price_mwk = excluded.price_mwk,
    billing_interval = excluded.billing_interval,
    currency = excluded.currency,
    active = excluded.active,
    sort_order = excluded.sort_order,
    features = excluded.features,
    marketing = excluded.marketing;
end $$;
