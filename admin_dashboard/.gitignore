# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (keep secrets untracked, but commit the template)
.env*
!.env.example
!.env.local.example

# consumer app env asset (commit template only)
supabase.env.json
!supabase.env.json.example

# firebase admin credentials (never commit)
firebase-service-account.json
serviceAccountKey.json

# supabase local temp artifacts (never commit)
supabase/.temp/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
.env*.local
