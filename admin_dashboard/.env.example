# Client-safe
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Admin backend (server-only)
# Points the admin dashboard to the NestJS API origin.
# Local example: http://127.0.0.1:3000
# Production example: https://api.yourdomain.com
ADMIN_BACKEND_BASE_URL=

# Admin allowlist (server-only)
# Comma-separated emails allowed to access /dashboard and /admin
ADMIN_EMAILS=

# Admin guard secret (server-only)
# Required. Used to sign/verify the `admin_guard` cookie in middleware.
# Use a long random string (32+ chars). Example (macOS):
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_GUARD_SECRET=

# Firebase (client-safe)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Server-only (keep secret; never expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# Internal push send endpoint (server-only)
# Used by /api/push/send for backend-triggered notifications (likes/comments/trending etc)
PUSH_INTERNAL_SECRET=

# Sentry monitoring (optional)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_REPLAYS_SESSION_SAMPLE_RATE=0.1
SENTRY_REPLAYS_ON_ERROR_SAMPLE_RATE=1.0

# Firebase Admin (server-only)
# Set exactly one of these:
# Optional (recommended for local emulators): explicit project id for the Admin SDK.
# If you use FIREBASE_AUTH_EMULATOR_HOST, you must set this.
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account"}
# FIREBASE_SERVICE_ACCOUNT_BASE64=

# Optional: protects the risk scan endpoint if you use it
RISK_SCAN_SECRET=

# Optional: Edge Function /api/diag access in production
# Note: Supabase Edge Functions use their own Secrets; set the same value there.
WEAFRICA_DEBUG_DIAG_TOKEN=

# Analytics events ingest (server-only)
# Used by POST /api/events/ingest
EVENTS_INGEST_SECRET=

# Subscriptions (PayChangu + renewals)
# Used by POST /api/webhooks/paychangu
PAYCHANGU_WEBHOOK_SECRET=

# Subscription kickoff (returns a checkout_url)
# Used by POST /api/paychangu/start
# Set one of:
# - PAYCHANGU_CHECKOUT_URL (fallback for all plans)
# - PAYCHANGU_CHECKOUT_URL_<PLANID> (per-plan override; PLANID uppercased/sanitized, e.g. PREMIUM_WEEKLY)
PAYCHANGU_CHECKOUT_URL=
PAYCHANGU_CHECKOUT_URL_PREMIUM=
PAYCHANGU_CHECKOUT_URL_PREMIUM_WEEKLY=
PAYCHANGU_CHECKOUT_URL_PLATINUM=
PAYCHANGU_CHECKOUT_URL_PLATINUM_WEEKLY=

# Used by POST /api/cron/subscriptions/expire (header: x-cron-secret)
SUBSCRIPTIONS_CRON_SECRET=

# Live streaming (Agora)
# App ID is safe to store server-side; required by your consumer app for RTC.
AGORA_APP_ID=

# Required to mint Agora RTC tokens (keep secret; server-only)
AGORA_APP_CERTIFICATE=

# Required for REAL stop/kick from the admin dashboard via Agora Channel Management REST API.
# Get these from Agora Console → RESTful API.
AGORA_CUSTOMER_ID=
AGORA_CUSTOMER_SECRET=

# Optional: if you want the admin dashboard to actually terminate Agora channels,
# point it at your own secured backend (Cloud Function/API) that performs Agora REST calls.
LIVE_STREAM_STOP_WEBHOOK_URL=
LIVE_STREAM_STOP_WEBHOOK_SECRET=

# Optional: Featured Artists AI reranking (free tier via Hugging Face)
# If not set, the Featured Artists "Suggest" feature falls back to a free heuristic.
HUGGINGFACE_API_KEY=
# Example models: mistralai/Mistral-7B-Instruct-v0.3, google/flan-t5-xl
HUGGINGFACE_FEATURED_ARTISTS_MODEL=
