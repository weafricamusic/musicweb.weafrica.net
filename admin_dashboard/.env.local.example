# Copy to .env.local for local development.
# For the full list of supported variables, see .env.example.

# Firebase Admin (server-only)
# Recommended: explicit project id (required when using the Firebase Auth Emulator).
FIREBASE_PROJECT_ID=weafrica-music-85cdc

# Optional: used for calling the deployed Supabase Edge Function diagnostics endpoint in production.
# Set the same value as the Supabase Edge Function secret WEAFRICA_DEBUG_DIAG_TOKEN,
# then call GET $BASE_URL/api/diag with header: x-debug-token: <value>
WEAFRICA_DEBUG_DIAG_TOKEN=
