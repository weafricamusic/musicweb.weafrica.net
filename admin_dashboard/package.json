{
  "name": "weafrica-music-admin",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "predev": "node scripts/check-node-version.mjs",
    "dev": "node scripts/next-dev.mjs",
    "dev:lan": "node scripts/next-dev.mjs --hostname 0.0.0.0 --port 3000",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint",
    "setup:env": "node scripts/setup-env.mjs",
    "setup:firebase-admin": "node scripts/setup-firebase-admin.mjs",
    "setup:supabase": "node scripts/setup-supabase-env.mjs",
    "ensure:test-accounts": "node scripts/ensure-test-accounts.mjs",
    "smoke:consumer": "node scripts/smoke-subscription-consumer.mjs",
    "smoke:consumer:real": "SMOKE_REAL=1 node scripts/smoke-subscription-consumer.mjs",
    "check:firebase-admin": "node scripts/check-firebase-admin.mjs",
    "check:firebase-admin:token": "node scripts/check-firebase-admin.mjs --token",
    "check:supabase-env": "node scripts/check-supabase-env.mjs",
    "backup:db": "bash scripts/backup.sh"
  },
  "dependencies": {
    "@ffmpeg/ffmpeg": "^0.12.15",
    "@ffmpeg/util": "^0.12.2",
    "@sentry/nextjs": "^10.32.1",
    "@supabase/supabase-js": "^2.90.1",
    "dotenv": "^17.2.3",
    "firebase": "^12.7.0",
    "firebase-admin": "^13.6.0",
    "ffmpeg-static": "^5.2.0",
    "jose": "^6.1.3",
    "lucide-react": "^0.563.0",
    "next": "16.1.1",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "ffmpeg-static": "^5.2.0",
    "eslint-config-next": "16.1.1",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "typescript": "5.9.3"
  }
}
