class _LiveFloatingCommentsOverlay extends StatefulWidget {
  const _LiveFloatingCommentsOverlay({required this.liveId});

  final String liveId;

  @override
  State<_LiveFloatingCommentsOverlay> createState() => _LiveFloatingCommentsOverlayState();
}

class _LiveFloatingCommentsOverlayState extends State<_LiveFloatingCommentsOverlay> {
  Timer? _tick;

  @override
  void initState() {
    super.initState();
    _tick = Timer.periodic(const Duration(seconds: 1), (_) {
      if (mounted) setState(() {});
    });
  }

  @override
  void dispose() {
    _tick?.cancel();
    super.dispose();
  }

  double _opacityForAge(Duration age) {
    final seconds = age.inMilliseconds / 1000.0;
    if (seconds <= 1.2) return 1.0;
    if (seconds >= 10) return 0.0;
    final t = (seconds - 1.2) / (10 - 1.2);
    return (1 - t).clamp(0.0, 1.0);
  }

  @override
  Widget build(BuildContext context) {
    final liveId = widget.liveId.trim();
    if (liveId.isEmpty) return const SizedBox.shrink();

    return StreamBuilder<List<ChatMessageModel>>(
      stream: ChatService().watchMessages(liveId: liveId, limit: 20),
      builder: (context, snapshot) {
        final List<ChatMessageModel> messages =
            (snapshot.data ?? const <ChatMessageModel>[]).cast<ChatMessageModel>();
        final now = DateTime.now().toUtc();
        final List<ChatMessageModel> visible = messages.where((ChatMessageModel entry) {
          final age = now.difference(entry.timestamp.toUtc());
          return age.inSeconds <= 12 && entry.message.trim().isNotEmpty;
        }).take(5).toList(growable: false);
        if (visible.isEmpty) return const SizedBox.shrink();

        return Column(
          crossAxisAlignment: CrossAxisAlignment.start,
          mainAxisSize: MainAxisSize.min,
          children: [
            for (final msg in visible)
              Padding(
                padding: const EdgeInsets.only(bottom: 6),
                child: Opacity(
                  opacity: _opacityForAge(now.difference(msg.timestamp.toUtc())),
                  child: ClipRRect(
                    borderRadius: BorderRadius.circular(16),
                    child: BackdropFilter(
                      filter: ImageFilter.blur(sigmaX: 14, sigmaY: 14),
                      child: Container(
                        padding: const EdgeInsets.symmetric(horizontal: 10, vertical: 7),
                        decoration: BoxDecoration(
                          color: Colors.black.withValues(alpha: 0.30),
                          borderRadius: BorderRadius.circular(16),
                          border: Border.all(color: Colors.white.withValues(alpha: 0.08)),
                        ),
                        child: RichText(
                          text: TextSpan(
                            children: [
                              TextSpan(
                                text: '${msg.userName}: ',
                                style: const TextStyle(
                                  color: WeAfricaColors.gold,
                                  fontWeight: FontWeight.w900,
                                  fontSize: 12,
                                ),
                              ),
                              TextSpan(
                                text: msg.message,
                                style: const TextStyle(
                                  color: Colors.white,
                                  fontWeight: FontWeight.w700,
                                  fontSize: 12,
                                ),
                              ),
                            ],
                          ),
                        ),
                      ),
                    ),
                  ),
                ),
              ),
          ],
        );
      },
    );
  }
}

class _LiveFloatingHeartsLayer extends StatelessWidget {
  const _LiveFloatingHeartsLayer({required this.hearts});

  final List<_LiveFloatingHeart> hearts;

  @override
  Widget build(BuildContext context) {
    return Stack(
      fit: StackFit.expand,
      children: hearts
          .map(
            (heart) => Positioned(
              left: heart.origin.dx,
              top: heart.origin.dy,
              child: heart,
            ),
          )
          .toList(growable: false),
    );
  }
}

class _LiveFloatingHeart extends StatefulWidget {
  const _LiveFloatingHeart({
    super.key,
    required this.onComplete,
    required this.color,
    required this.driftX,
    required this.origin,
  });

  final void Function(_LiveFloatingHeart) onComplete;
  final Color color;
  final double driftX;
  final Offset origin;

  @override
  State<_LiveFloatingHeart> createState() => _LiveFloatingHeartState();
}

class _LiveFloatingHeartState extends State<_LiveFloatingHeart>
    with SingleTickerProviderStateMixin {
  late final AnimationController _controller;
  late final Animation<double> _opacity;
  late final Animation<double> _dy;
  late final Animation<double> _dx;
  late final Animation<double> _scale;

  @override
  void initState() {
    super.initState();
    _controller = AnimationController(
      duration: const Duration(milliseconds: 1800),
      vsync: this,
    );
    final curve = CurvedAnimation(parent: _controller, curve: Curves.easeOutCubic);
    _dy = Tween<double>(begin: 0, end: -190).animate(curve);
    _dx = Tween<double>(begin: 0, end: widget.driftX).animate(curve);
    _scale = Tween<double>(begin: 0.92, end: 1.3).animate(curve);
    _opacity = TweenSequence<double>([
      TweenSequenceItem(tween: Tween<double>(begin: 0.0, end: 1.0), weight: 18),
      TweenSequenceItem(tween: Tween<double>(begin: 1.0, end: 0.0), weight: 82),
    ]).animate(curve);
    _controller.forward().whenComplete(() => widget.onComplete(widget));
  }

  @override
  Widget build(BuildContext context) {
    return AnimatedBuilder(
      animation: _controller,
      builder: (context, child) {
        return Transform.translate(
          offset: Offset(_dx.value, _dy.value),
          child: Opacity(
            opacity: _opacity.value,
            child: Transform.scale(scale: _scale.value, child: child),
          ),
        );
      },
      child: Icon(Icons.favorite, color: widget.color, size: 26),
    );
  }

  @override
  void dispose() {
    _controller.dispose();
    super.dispose();
  }
}